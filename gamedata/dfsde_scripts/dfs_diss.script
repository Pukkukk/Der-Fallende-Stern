function horror_voice()
		
		local snd_obj			= xr_sound.get_safe_sound_object( [[dfs\rnd_the_horror2]] )
		snd_obj:play_no_feedback(db.actor, sound_object.s2d, 0, vector(), 1.0)
		level.add_cam_effector("camera_effects\\earthquake.anm", 1974, false, "")
end

function horror_voice_2()
		local snd_obj			= xr_sound.get_safe_sound_object( [[dfs\whistling_wind1]] )
		snd_obj:play_no_feedback(db.actor, sound_object.s2d, 0, vector(), 1.0)
end



