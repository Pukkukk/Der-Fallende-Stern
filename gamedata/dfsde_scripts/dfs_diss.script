function prip_timer_c4_1_on()
	this.object_on(20843)
end

function prip_timer_c4_2_on()
	this.object_on(20844)
end


function object_on(sid)
	local obj = alife():story_object(sid)
	if obj then
	alife():set_switch_offline(obj.id, false)
	alife():set_switch_online(obj.id, true)
	alife():set_interactive(obj.id, true)
	end
end

function prip_target_1()
	local hitter = level_object_by_sid(20843)
    if hitter then
	this.prip_mobile_expl(20843, hitter)
	this.prip_mobile_shok(20394, hitter)
	this.prip_mobile_expl(20397, hitter)
	end
end

function prip_target_2()
	local hitter = level_object_by_sid(20844)
    if hitter then
	this.prip_mobile_expl(20844, hitter)
	this.prip_mobile_shok(20393, hitter)
	this.prip_mobile_expl(20398, hitter)
	end
end

function prip_mobile_expl(sid, draftsman)
	local mbl = level_object_by_sid(sid)
	if mbl == nil then
		return
	end
	local h = hit()
	h.power = 1000000
	h.direction = vector():set( 0, 0, 0 )
	h.draftsman = draftsman 
	h.impulse = 0
	h.type = hit.explosion
	mbl:hit(h)
end

function prip_mobile_shok(sid, draftsman)
	local mbl = level_object_by_sid(sid)
	if mbl == nil then
		return
	end
	local h = hit()
	h.power = 1000000
	h.direction = vector():set( 0, 0, 0 )
	h.draftsman = draftsman 
	h.impulse = 0
	h.type = hit.shock
	mbl:hit(h)
end

function zont( pos, lvid, gvid, vis, mass, fixed_bones,sect1 ) 
  local sobj = alife():create( sect1, pos, lvid, gvid )
  local pk = get_netpk( sobj, 1 )
  local data = pk:get()
  data.visual_name = vis or "physics\\art_sharik"
  data.custom_data:setString("[logic]\ncfg = scripts\\dfs\\renn_taynik.ltx\n[collide]\nignore_static\n")
  data.physic_type = 3
  data.mass        = mass or 1
  data.fixed_bones = fixed_bones or "joint1"
  pk:set(data)
  return sobj
end