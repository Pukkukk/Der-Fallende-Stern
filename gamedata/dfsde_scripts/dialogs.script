end

function degenerates_kba(actor, npc)
	if	db.actor:has_info("yo_bastard_01_kba") and
		db.actor:has_info("yo_bastard_02_kba") and
		db.actor:has_info("yo_bastard_03_kba") and
		db.actor:has_info("yo_bastard_04_kba") and
		db.actor:has_info("yo_bastard_05_kba") and
		db.actor:has_info("yo_bastard_06_kba") then
	return true
	end
	return false
end

function degenerates_nkba(actor, npc)
	if	db.actor:dont_has_info("yo_bastard_01_kba") or
		db.actor:dont_has_info("yo_bastard_02_kba") or
		db.actor:dont_has_info("yo_bastard_03_kba") or
		db.actor:dont_has_info("yo_bastard_04_kba") or
		db.actor:dont_has_info("yo_bastard_05_kba") or
		db.actor:dont_has_info("yo_bastard_06_kba") then
	return true
	end
	return false
end

