function save(packet)
	packet:w_stringZ("artmgr")
	packet:w_stringZ(lev_str)
	packet:w_stringZ(lev_cur_sav)
	utils.w_CTime(packet, spawn_time)
end

function load(packet)
	local flag = packet:r_stringZ()
	if flag ~= "artmgr" then
		del_xlam()
--		dbglog("First startup of Artefact Respawn Script 1.0")
		return
	end
	lev_str = packet:r_stringZ()
	lev_cur_sav = packet:r_stringZ()
	spawn_time = utils.r_CTime(packet)
end

function update()
	local time = time_global()
	if update_time == nil then
		update_time = time + 14000
	elseif update_time < time then
		update_time = time + 14000
		local game_time = game.get_game_time()
		if spawn_time == nil then
			spawn_time = game_time
		end
		if game_time >= spawn_time then
			spawn_time = game.CTime() spawn_time:setHMSms(math.random(minHH, maxHH),0,0,0)
			spawn_time = spawn_time + game_time
--		local blowout = ...
--		if blowout == true then
			lev_cur_sav, lev_str = "", ""
--			dbglog("Next Spawn Date:%s,Time:%s", spawn_time:dateToString(0), spawn_time:timeToString(1))
--			return
		end
		exec()
	end
end

function exec()
	local lev_cur = level.name()

	if lev_cur_sav ~= lev_cur then
		local lev_cur_tbl = lev[lev_cur]
		if lev_cur_tbl == nil then
			get_console():execute("!!!!!!!!!!CAN NOT FIND LEVEL NAME IN TABLE:[lev]!!!!!!!!!!")
			get_console():execute("flush")
		end
		local lid = lev_cur_tbl.id
		if not string.find(lev_str, lid) then
			local a_tbl, lev_tbl = {}, {}
			local sim = alife()
			math.randomseed(time_global())
			local r = math.random(25,60)
			local qtt = lev_cur_tbl.qtt
			local dist = math.random(lev_cur_tbl.dmin, lev_cur_tbl.dmax)
			
			table.insert(lev_tbl, lid)
			table.insert(lev_tbl, lev_str)
			lev_str=table.concat(lev_tbl)
--			dbglog("Table:[lev_tbl]converted to string:[lev_str=%s]", lid)
			lev_cur_sav = lev_cur
			if qtt == 0 then return end
			
			local actor = db.actor
			for id=1,65534 do
			local obj = level.object_by_id(id)
				if obj then
					local a_cls = obj:clsid()
					if
						a_cls == clsid.zone_bfuzz_s or
						a_cls == clsid.zone_galant_s or
						a_cls == clsid.zone_mbald_s or
						a_cls == clsid.zone_mincer_s
					then
						if actor:position():distance_to(obj:position()) > r then
							table.insert(a_tbl, obj:id())
						end
--						for i,v in pairs(a_tbl) do
--							if distance_between_safe(level.object_by_id(v), obj) > 0 and distance_between_safe(level.object_by_id(v), obj) < dist then
--								table.remove(a_tbl)
--							end
--						end
					end
				end
			end

			if qtt > 0 then
				create_art(obj,qtt,a_tbl)
			end
		end
	end
end

-- —оздаЄм артефаки
function create_art(obj,qtt,a_tbl)
local lev_cur = level.name()
local find_art = 0
local actor_vid = game_graph():vertex(alife():actor().m_game_vertex_id):level_id()
for id=1,65535 do
		local npc = alife():object(id)
		if npc then
			local npc_vid 	= game_graph():vertex(npc.m_game_vertex_id):level_id()
			if actor_vid == npc_vid then
				local obj1 = alife():object(id)
				if obj1 then
					local arty = obj1:section_name()
					if string.sub(arty,1,3) =="af_" and obj1.parent_id == 65535  then
--level.map_add_object_spot(obj1.id, "red_location", arty)
						find_art = find_art +1

					end
				end
			end
		end
end


if find_art > 10 then
	qtt = 0
end


for n=1,qtt do
				local cnt = table.getn(a_tbl)
				if cnt > 0 then
					local id = math.random(cnt)
					local obj = level.object_by_id(a_tbl[id])
					table.remove(a_tbl, id)
	if obj == nil then
		return
	end
	if find_art == nil then
		find_art = 0
	end

	local key
	local sect = obj:section()
	if string.find(sect, "buzz") then
		key = "buzz"
	elseif string.find(sect, "zharka") then
		key = "zharka"
	elseif string.find(sect, "mosquito") then
		key = "mosquito"
	elseif string.find(sect, "mincer") then
		key = "mincer"
	elseif string.find(sect, "gravi") then
		key = "gravi"
	elseif string.find(sect, "witches") then
		key = "witches"
	elseif string.find(sect, "burning") then
		key = "burning"
	end

	if key then
		local lv = obj:level_vertex_id()
		local gv = obj:game_vertex_id()
		local pos = obj:position()
		local off_x = 2
		local off_y = 5
		local off_z = 2
		pos.x = pos.x + off_x
		pos.y = pos.y + off_y
		pos.z = pos.z + off_z
		
		if lv and gv and pos then
			local lev_cur = level.name()
			local sec = rwc(arts[key])
			local art = alife():create(sec, pos, lv, gv)
			local art_inv = game.translate_string(system_ini():r_string(art:section_name(), "inv_name"))
			local text = (game.translate_string("art_mgr_1")) .. lev_cur .. (game.translate_string("art_mgr_2")) ..sect.. (game.translate_string("art_mgr_3")) .. art_inv
--log1(text)
--			level.map_add_object_spot(art.id, "red_location", text)
--db.actor:give_game_news("ѕроведен доспавн артефактов.", "ui\\ui_iconsTotal",Frect():set(0,188,83,47) ,0, 5000)
		else
			get_console():execute("!!!!!!!!!!FUCK MY BRAIN!!!!!!!!!!")
			get_console():execute("flush")
		end
	end




				end
			end

end

-- random weighted choice
function rwc(t)
	local sum = 0
	local rnd = math.random(100)
	for i,v in ipairs(t) do
		sum = sum + v[2]
		if rnd <= sum then
--			dbglog("rnd=[%d],weight=[%d],sum=[%d],Artefact section:[%s]",rnd,v[2],sum,v[1])
			return v[1]
		end
	end
end

-- ”даление навозных куч артефактов, хал€вной брони и читерских €щиков с лутом
function del_xlam()
	local del_art, del_suit, del_box = true, false, false
	local sim = alife()
	local packet = net_packet()
	for id=1, 65534 do
		local obj = sim:object(id)
		if obj then
			local gvid, l_id
			if del_art == true then
				local sect = obj:section_name()
				if
					sect == "af_blood" or
					sect == "af_cristall_flower" or
					sect == "af_drops" or
					sect == "af_fireball" or
					sect == "af_medusa" or
					sect == "af_mincer_meat" or
					sect == "af_vyvert" 
				then
					gvid = obj.m_game_vertex_id
					l_id = game_graph():vertex(gvid):level_id()
--					if l_id < 14 and l_id ~= 4 and l_id ~= 6 and l_id ~= 10 and l_id ~= 12 then
						sim:release(obj)
--					end
				end
			end
			if del_suit == true and obj:clsid() == clsid.equ_stalker_s and
				not string.find(obj:name(), "esc_outfit_bandit_m1") and
				obj.parent_id == 65535
			then
				sim:release(obj)
			end
			if del_box == true and obj:clsid() == clsid.obj_phys_destroyable then
				packet:w_begin(0)
				obj:STATE_Write(packet)
				packet:r_seek(2)
				
				local game_vertex_id = packet:r_u16()
				local distance = packet:r_float()
				local direct_control = packet:r_s32()
				local level_vertex_id = packet:r_s32()
				local object_flags = packet:r_s32()
				local custom_data = packet:r_stringZ()
				local story_id = packet:r_s32()
				local spawn_story_id = packet:r_s32()
				local visual_name = packet:r_stringZ()
				
				if visual_name then
					gvid = obj.m_game_vertex_id
					l_id = game_graph():vertex(gvid):level_id()
					if string.find(visual_name, "box_wood") or
						(string.find(visual_name, "box_metall") and l_id < 14 and l_id ~= 4 and l_id ~= 6 and l_id ~= 10 and l_id ~= 12)
					then
						sim:release(obj)
					end
				end
			end
		end
	end
end
