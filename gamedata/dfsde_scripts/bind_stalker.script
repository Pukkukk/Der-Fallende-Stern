----------------------------------------------------------------------------------------------------------------------
function actor_binder:on_item_drop (obj)
    level_tasks.proceed(self.object)
	amk.on_item_drop(obj)
	hidden_slots.on_item_drop(obj)
	inventory.on_item_drop(obj)
	use_key.item_drop(obj)
	use_key.drop_knifes(obj)
		
end
----------------------------------------------------------------------------------------------------------------------
function actor_binder:use_obj(obj) 
 synchro_item.on_use(obj) 
end
------------------------------------------------------------------
function actor_binder:task_callback(_task, _objective, _state)
	task_manager.task_callback(_task:get_id(), _objective:get_idx(), _state)
	if _objective:get_idx() == 0 then
		if _state == task.fail then
			news_manager.send_task(db.actor, "fail", _task, _objective)
		elseif _state == task.completed then
			task_manager.reward_by_task(_task)
			news_manager.send_task(db.actor, "complete", _task, _objective)
		else
			news_manager.send_task(db.actor, "new", _task, _objective)
		end
	else
		if _task:get_objective(0):get_state() == task.in_progress then
			news_manager.send_task(db.actor, "update", _task, _objective)
		end
	end
end

----------------------------------------------------------------------------------------------------------------------
function actor_binder:map_location_added_callback(spot_type_str, object_id)
	if (false==app_ready()) or (device().precache_frame>1) then return end
	--'news_manager.send_task(db.actor, "new")
end
----------------------------------------------------------------------------------------------------------------------
function actor_binder:update(delta)
	object_binder.update(self, delta)

	local time = time_global()
	
	game_stats.update (delta, self.object)
--	time_on_hud.show_time()
	ui_loader.update()
	ui_loader_hud.update()
	
	if not has_alife_info ("ubil") and
		xr_conditions.killed_by_actor then
		xr_conditions.nizzjaa_1()
	end
	
	if (level.name() == "labx8") then
		xr_conditions.biolab_gase()
	end
	
	if	(level.name() == "predbannik") and
		has_alife_info ("is_infected_plague") and
		not has_alife_info ("zaglushka_41") then
		xr_effects.infection_hit()
	end
	
	if	(level.name() == "warlab") and
		not has_alife_info ("destroy_barier_control_start") and
		has_alife_info ("hide_all_done") then
		hide_weapon()
	end
	
	if	(level.name() == "warlab") and
		has_alife_info ("destroy_barier_control_start") then
		restore_weapon()
	end
	
	if	has_alife_info ("has_kira_pribor") and
		has_alife_info ("taked_mzda") and
		not has_alife_info ("get_access_over_barrier") then
		xr_effects.broken_invertor_nax()
		xr_effects.good_invertor_vax()
		self.object:give_info_portion("get_access_over_barrier")
	end
	
	if not has_alife_info("zaglushka_66") and
		has_alife_info("zaglushka_65") then
		dfs_static_part.timer_static()
		dfs_static_part.hud_static_part("timer_boom")
	end
	
	if has_alife_info ("ubil") then 
			dfs_static_part.timer_static_taboo()
			dfs_static_part.hud_static_dont_kill("dont_kill")
	end
	
	if has_alife_info ("have_noticed") then 
			dfs_static_part.timer_static_taboo()
			dfs_static_part.hud_static_have_noticed("you_have_noticed")
	end
	
	if has_alife_info ("you_lost") then 
			dfs_static_part.timer_static_barier_1()
			dfs_static_part.hud_static_you_lost("you_have_lost")
	end
	
	if	has_alife_info ("you_vin") then 
			dfs_static_part.timer_static_barier_2()
			dfs_static_part.hud_static_you_vin("you_have_vin")
	end
	
	if	has_alife_info ("you_get_nomoney") then 
			dfs_static_part.timer_static_barier_3()
			dfs_static_part.hud_static_you_vin("you_have_lost")
	end
	
	if	has_alife_info ("you_fin_mission") then 
			dfs_static_part.timer_static_barier_4()
			dfs_static_part.hud_static_you_vin("you_have_lost")
	end
	
	if not has_alife_info ("static_0") and
		has_alife_info("zaglushka_92") then
		dfs_static_part.timer_static()
		dfs_static_part.hud_static_part("static_0")
	end
	
	if not has_alife_info ("static_1") and
		has_alife_info("zaglushka_93") then
		dfs_static_part.timer_static()
		dfs_static_part.hud_static_part("static_1")
	end
	
	if not has_alife_info ("static_2") and
		has_alife_info("zaglushka_94") then
		dfs_static_part.timer_static()
		dfs_static_part.hud_static_part("static_2")
	end
	
	if not has_alife_info ("static_3") and
		has_alife_info("zaglushka_95") then
		dfs_static_part.timer_static()
		dfs_static_part.hud_static_part("static_3")
	end
	
	if not has_alife_info ("static_4") and
		has_alife_info("zaglushka_135") then
		dfs_static_part.timer_static()
		dfs_static_part.hud_static_part("static_4")
	end
	
	if not has_alife_info ("static_5") and
		has_alife_info("zaglushka_147") then
		dfs_static_part.timer_static()
		dfs_static_part.hud_static_part("static_5")
	end
	
	if not has_alife_info ("static_6") and
		has_alife_info("zaglushka_216") then
		dfs_static_part.timer_static()
		dfs_static_part.hud_static_part("static_6")
	end

		if not has_alife_info ("zaglushka_103_ubil") and 
		has_alife_info("zaglushka_103")  and
		   (level.name() == "l12_stancia_2") then
		   xr_effects.ml_dead()
		end

	-- апдейт погоды
	self.weather_manager:update()
	
	-- апдейт схемы детектора
	self.actor_detector:update()

	-- апдейт звуковой схемы актера
	xr_sound.update_actor()
	
	--' Проверка потери жизни
--[[
	if self.object.health - lasthealth > 0.001 or
	   self.object.health - lasthealth < -0.001 then
		printf("%f | %f", self.object.health, self.object.health - lasthealth, game.time() - lasttime)
		lasthealth = self.object.health
		lasttime = game.time()
	end
]]	
	-- Обновление отключения ввода с клавиатуры.
	if self.st.disable_input_time ~= nil and
	   game.get_game_time():diffSec(self.st.disable_input_time) >= self.st.disable_input_idle 
	then
		level.enable_input()
		self.st.disable_input_time = nil
	end
	-- Обновление сна с переносом чувака в указанную позицию
	if self.st.sleep_relocate_time ~= nil and
	   game.get_game_time():diffSec(self.st.sleep_relocate_time) >= self.st.sleep_relocate_idle 
	then
		self.object:set_actor_position(self.st.sleep_relocate_point)
		local dir = self.st.sleep_relocate_point:sub(self.st.sleep_relocate_look)
		self.object:set_actor_direction(dir:getH())
		self.st.sleep_relocate_time = nil
	end

	-- Апдейт прятание оружия игрока во время диалога
	if weapon_hide == true or self.object:is_talking() then
		if self.weapon_hide == false then
			self.object:hide_weapon()
			self.weapon_hide = true
		end
	else
		if self.weapon_hide == true then
			self.object:restore_weapon()
			self.weapon_hide = false
		end
	end	
	if db.actor then
		if has_alife_info("ui_inventory") then
			ui_cop_rad.add_rad_empty()
			ui_cop_blood.add_blood_empty()
		else
			ui_cop_rad.remove_rad_empty()
			ui_cop_blood.remove_blood_empty()
		end
	end

	if db.actor then
		if has_alife_info("ui_inventory") then
			ui_cop_rad.add_rad_green()
			ui_cop_rad.add_rad_yellow()
			ui_cop_rad.add_rad_orange()
			ui_cop_rad.add_rad_red()
		else
			ui_cop_rad.remove_rad_green()
			ui_cop_rad.remove_rad_yellow()
			ui_cop_rad.remove_rad_orange()
			ui_cop_rad.remove_rad_red()
		end
	end

	if db.actor then
		if has_alife_info("ui_inventory") then
			ui_cop_blood.add_blood_green()
			ui_cop_blood.add_blood_yellow()
			ui_cop_blood.add_blood_orange()
			ui_cop_blood.add_blood_red()
		else
			ui_cop_blood.remove_blood_green()
			ui_cop_blood.remove_blood_yellow()
			ui_cop_blood.remove_blood_orange()
			ui_cop_blood.remove_blood_red()
		end
	end

	-- обновление рестрикторов, которые под логикой, срабатывает через интервалы времени
	if self.next_restrictors_update_time < time then
		bind_restrictor.actor_update(delta)
		
		-- Апдейтим наш телепорт
		bind_mteleport.actor_update(delta)

		self.next_restrictors_update_time = time + 200

		task_manager.actor_update()
	end

	-- обновление постпроцессов
	if post_process ~= 0 then
		if post_process:update () == true then
		   post_process = 0
		end
	end

	-- обновление пси-антенны
	if sr_psy_antenna.psy_antenna then
		sr_psy_antenna.psy_antenna:update(delta)
	end
	
	--' Вывод сообщения о большой радиации
	if self.object.radiation >= 0.7 then
		local hud = get_hud()
		local custom_static = hud:GetCustomStatic("cs_radiation_danger")
		if custom_static == nil then
			hud:AddCustomStatic("cs_radiation_danger", true)
			hud:GetCustomStatic("cs_radiation_danger"):wnd():SetTextST("st_radiation_danger")
		end
	else
		local hud = get_hud()
		local custom_static = hud:GetCustomStatic("cs_radiation_danger")
		if custom_static ~= nil then
			hud:RemoveCustomStatic("cs_radiation_danger")
		end
	end

	inventory.update()

--' Запускаем затычку от возможной потери содержимого тайников
	treasure_manager.get_treasure_manager():loss_workaround()

 	if self.bCheckStart then
		printf("SET DEFAULT INFOS")
		
		if not has_alife_info("storyline_actor_start") and
		has_alife_info("never") and
		   (level.name() == "l01_escape")
		then
			self.object:give_info_portion("storyline_actor_start")
			_G.g_start_avi = true
