			not	has_alife_info("player_complete_leave_imperceptibly") and
				((level.name() == "l12_stancia") or
				(level.name() == "l10_radar") or
				(level.name() == "red_forest"))
		then
			self.object:give_info_portion("player_complete_leave_imperceptibly")
			self.object:give_info_portion("info_dfs_story_ar_38")			
		end
		
		if 	has_alife_info("dagger_for_sinner_start") and
			not	has_alife_info("dagger_for_sinner_1") and
				(level.name() == "aver")
		then
			self.object:give_info_portion("dagger_for_sinner_1")			
		end
		
		if 	has_alife_info("dagger_for_sinner_2") and
			not	has_alife_info("dagger_for_sinner_failed") and
				(level.name() == "red_forest")
		then
			self.object:give_info_portion("dagger_for_sinner_failed")			
		end
		
		if 	has_alife_info("old_dead_city_start") and
			not	has_alife_info("player_complete_old_dead_city") and
				(level.name() == "dead_city")
		then
			self.object:give_info_portion("player_complete_old_dead_city")
			self.object:give_info_portion("player_complete_find_way_dc")
		end
		
		if not has_alife_info("player_complete_get_out_dc") and
			has_alife_info("get_out_dc_start") and
			(level.name() == "l12_stancia_2") then
			self.object:give_info_portion("player_complete_get_out_dc")
			self.object:give_info_portion("self_evapoint_start")
		end
		
		if not has_alife_info("player_complete_get_car_out_dc") and
			has_alife_info("get_car_out_dc_start") and
			(level.name() == "l12_stancia_2") then
			self.object:give_info_portion("player_complete_get_car_out_dc")
		end
		
		if not has_alife_info("car_evapoint_start") and
			has_alife_info("player_complete_get_car_out_dc") and
			(level.name() == "l12_stancia_2") then
			dfs_messages.hugo_msg_3()
			self.object:give_info_portion("car_evapoint_start")
		end
		
		if not has_alife_info("episode_iii_start") and
			(level.name() == "dead_city") then
			self.object:give_info_portion("episode_iii_start")
		end
		
		if	has_alife_info("aggravated_scent_start") and
			(level.name() == "pripyat") then
			xr_effects.w_pri_add_marks()
		end
		
		if	has_alife_info("sinner_items_start") and
			(level.name() == "aver") then
			xr_effects.add_mark_sinner_shron()
		end
		
		if not has_alife_info("zaglushka_246") then
			alife():create("dfs_ibox_21",vector():set(127.61004638672,-9.2264137268066,-3.2697858810425),4739,3867)
			self.object:give_info_portion("zaglushka_246")
		end
		
		if not has_alife_info("zaglushka_247") then
			alife():create("dfs_ibox_22",vector():set(46.618743896484,4.5110421180725,96.133636474609),27340,3331)
			self.object:give_info_portion("zaglushka_247")
		end
		
		if not has_alife_info("zapalilsya") then
			self.object:give_info_portion("zapalilsya")
		end
		
		if	xr_conditions.has_vampir() then
		if	not has_alife_info("zaglushka_252") and
			(level.name() == "pripyat") then
			xr_effects.vampir_nax()
			xr_effects.antivampir_vax()
			self.object:give_info_portion("zaglushka_252")
			end
		end
		
		if	not has_alife_info("leave_pripyat_crush") and
			has_alife_info("leave_pripyat_start") and
			(level.name() == "pripyat") then
			self.object:give_info_portion("leave_pripyat_crush")
		end
		
		if	not has_alife_info("invertor_deadout") and
			(level.name() == "yantar_old") then
			xr_effects.good_invertor_nax()
			xr_effects.broken_invertor_vax()
			self.object:give_info_portion("invertor_deadout")
		end
		
		if	has_alife_info("artefacts_for_ermol_start") and
			not has_alife_info("artefacts_for_ermol_crush") and
			not has_alife_info("player_complete_artefacts_for_ermol") and
			(level.name() == "warlab") then
			self.object:give_info_portion("artefacts_for_ermol_crush")
		end
		
		if	has_alife_info("dead_artefacts_start") and
			not has_alife_info("dead_artefacts_cruch") and
			not has_alife_info("player_complete_dead_artefacts") and
			(level.name() == "warlab") then
			self.object:give_info_portion("dead_artefacts_cruch")
		end
		
		if	has_alife_info("dolg_mekhanik_start") and
			not has_alife_info("dolg_mekhanik_crush") and
			not has_alife_info("player_complete_dolg_mekhanik") and
			(level.name() == "warlab") then
			self.object:give_info_portion("dolg_mekhanik_crush")
		end
		
		if	has_alife_info("find_miser_start") and
			not has_alife_info("find_miser_crush") and
			not has_alife_info("player_complete_find_miser") and
			(level.name() == "warlab") then
			self.object:give_info_portion("find_miser_crush")
		end
		
		if	has_alife_info("break_to_hospital_start") and
			not has_alife_info("player_complete_break_to_hospital") and
			(level.name() == "hospital") then
			self.object:give_info_portion("player_complete_break_to_hospital")
		end
		
		if	has_alife_info("monolith_portal_3") and
			not has_alife_info("player_complete_monolith_portal") and
			(level.name() == "pripyat") then
			self.object:give_info_portion("player_complete_monolith_portal")
		end
		
		if	has_alife_info("overhear_bazar_start") and
			not has_alife_info("player_complete_overhear_bazar") and
			not has_alife_info("overhear_bazar_3_cruch") and
			(level.name() ~= "l11_pripyat") then
			self.object:give_info_portion("overhear_bazar_3_cruch")
		end

		if not has_alife_info("level_changer_icons") then
			dfs_bar_minefield.bar_mines_deactivate()
			dfs_diss.stancia_lchs_diss()
			dfs_diss.yan_2_yan_old_diss()
			dfs_diss.lc_esc2marsh_dis()
			dfs_diss.ch_bar2mil_dissappear()
			dfs_diss.ch_rf2lim_dissappear()
			dfs_diss.pri_c4_dis()
			dfs_diss.yan_sosych_diss()
			dfs_diss.yan_sosych_diss_2()
			dfs_diss.w_pri_heli_dis()
			dfs_diss.lc_dc2aes2_dis()
			dfs_diss.ch_pri2west_pri_dissappear()
			dfs_diss.w_pri2generators_lch_dissappear()
			dfs_diss.w_pri_c4_dis()
			dfs_diss.lim_col_lch2hos_dissappear()
			dfs_diss.hos_koster_dissappear()
			dfs_diss.hos_keys_dis()
			dfs_diss.hos_key_lch_dis()
			dfs_diss.w_pri_zabor_dis()
			dfs_diss.wpri_lim_lch_dis()
			dfs_diss.swamp2lost_diss()
			dfs_diss.hell_heli_dissappear()
			dfs_diss.gen_heli_diss()
			dfs_diss.sor_projector_dis()
			self.object:give_info_portion("nightmare_start")
			self.object:give_info_portion("level_changer_icons")
		end

		if not has_alife_info("level_changer_icons") then
			dfs_diss.w_pri_c4_dis1()
		end
		xr_effects.car_hit()
		level_tasks.add_lchanger_location()
                synchro_item.on_spawn() 
		self.bCheckStart = false		
	end
        if dinamic_hud then
		dinamic_hud.update()
	end




	amk.on_actor_update()
	ui_loader.update() -- MonolithUI
	ui_loader_hud.update()
	if bind_art then bind_art.beep_art(delta) end
		if rx_ai then rx_ai.actor_update() end
	if xrs_ai then xrs_ai.actor_update(delta) end
	local sim = alife()
	if sim then
		local obj = sim:story_object(20171)
		if obj and
		has_alife_info("find_fly_pda") then
			level.map_add_object_spot(obj.id, "crlc_big", (game.translate_string("bind_stalker")))
		end
	end
	if upd_time5 < time then
		upd_time5 = time + 120000
	elseif upd_time4 < time then
		upd_time4 = time + 10000
		if (not has_alife_info ("spawn_arty") and (level.name() == "garbage_old")) then
		   dfs_spawn.arty_spawn()
		   self.object:give_info_portion("spawn_arty")
		end

	elseif upd_time3 < time then
		upd_time3 = time + 20000
		art_mgr.update()



	elseif upd_time2 < time then
		upd_time2 = time + 5000
		use_key.knifes_rotation()


	elseif upd_time1 < time then
		upd_time1 = time + 100
   	

	elseif upd_time < time then
		upd_time = time + 500
		use_key.update()
		this.hide_weapon_knife_d()
	end
       
end
----------------------------------------------------------------------------------------------------------------------
function actor_binder:save(packet)
  ASSERT(
    packet:w_tell() <= 7500,
    "actor packet size is critical: %s", packet:w_tell()
  )
--  log2( "~~Actor netpacket size %s", packet:w_tell() )
	if rx_ai then rx_ai.actor_save(packet) end
	local save_treasure_manager = true
	
	printf("actor_binder:save(): self.object:name()='%s'", self.object:name())
	object_binder.save(self, packet)

	--' Сохраняем уровень сложности
	if save_treasure_manager == true then
		packet:w_u8(level.get_game_difficulty() + 128)
	else
		packet:w_u8(level.get_game_difficulty())
	end


	--' Сохраняем данные об отключенном вводе
	if self.st.disable_input_time == nil then
		packet:w_bool(false)
	else
		packet:w_bool(true)
		utils.w_CTime(packet, self.st.disable_input_time)
	end

	xr_logic.pstor_save_all(self.object, packet)
	self.weather_manager:save(packet)

	self.actor_detector:save(packet)
	art_mgr.save(packet)

	if se_stor then
--		if to_log then to_log(script_name()..":save:size=["..(packet:w_tell() - size).."]") end --/#~#
		if event then --/ вызов через 'систему сигналов'
			event("actor_saved"):trigger()
		elseif type(se_stor.save) == 'function' then --/ 'прямой' вызов
			se_stor.save()
		end
	end

end

--/#+# [se_stor] сохранение в чанках данных из внешних модулей без публичного save(): --
function actor_binder:ext_save(pk)
	self.weather_manager:save(pk)
	self.actor_detector:save(pk)
end

----------------------------------------------------------------------------------------------------------------------
function actor_binder:load(reader)

	--/#+# for debug --------------------------------------------------
	local size = reader:r_tell()
	--/<---------------------------------------------------------------

	printf("actor_binder:load(): self.object:name()='%s'", self.object:name())
	object_binder.load(self, reader)
	printf("actor_binder:object_binder.load(): self.object:name()='%s'", self.object:name())

	--' Загружаем уровень сложности
	local game_difficulty = reader:r_u8()
	
	local load_treasure_manager = false      
	if game_difficulty >= 128 then           
		game_difficulty = game_difficulty - 128
		load_treasure_manager = true           
	end                                      

	
	get_console():execute("g_game_difficulty "..game_difficulty_by_num[game_difficulty])

	if reader:r_eof() then
		abort("SAVE FILE IS CORRUPT")
	end

	local stored_input_time = reader:r_u8()
	if stored_input_time == true then
		self.st.disable_input_time = utils.r_CTime(reader)
	end

	xr_logic.pstor_load_all(self.object, reader)
	self.weather_manager:load(reader)

	self.actor_detector:load(reader)	
	art_mgr.load(reader)

	if se_stor then
--		if to_log then to_log(script_name()..":load:size=["..(reader:r_tell() - size).."]") end --/#~#
		if event then --/ вызов через 'систему сигналов'
			event("actor_load"):trigger()
		elseif type(se_stor.load) == 'function' then --/ 'прямой' вызов
		se_stor.load()
		end
	end


end

--/#+# [se_stor] загрузка данных из чанков во внешние модули без публичного save(): ----
function actor_binder:ext_load(pk)
	self.weather_manager:load(pk)
	self.actor_detector:load(pk)
end
