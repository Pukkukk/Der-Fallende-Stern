function trunk_dialog:OnMsgYes()

	if self.msgbox_id == 1 then return
	end
	
	self.msgbox_id = 0
end

function get_x(item)
	local ini = system_ini()
	tx = ini:r_u32(item, "inv_grid_x")
	return tx
end

function get_y(item)
	local ini = system_ini()
    ty = ini:r_u32(item, "inv_grid_y")
	return ty
end

function get_w(item)
	local ini = system_ini()
	tw = ini:r_u32(item, "inv_grid_width")
	return tw
end

function get_h(item)
	local ini = system_ini()
    th = ini:r_u32(item, "inv_grid_height")
	return th
end

