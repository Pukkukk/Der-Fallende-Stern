end

--╨шёґхь ЁхьюэҐшЁґхь√щ яЁхфьхҐ
function trunk_dialog:DrawCurItem2(de_item, x, y)

if x == nil then x = 0 end
if y == nil then y = 0 end

	local di_section = de_item.section

	local scope = 0
	local launcher = 0
	local silence = 0

	local sect_addon
	local xa,ya,wa,ha
	local x_g,y_g,x_sco,y_sco,x_sil,y_sil
	local isGrenade=false
	local isScope=false
	local isSilencer=false
	
	local a = self.cur_rem_textur2
	local sys = system_ini()
	if not a then
		self.cur_rem_textur2 = CUIStatic()
		a = self.cur_rem_textur2
		a:SetWindowName("cur_rem_textur2")
		a:SetAutoDelete(true)	
		a:InitTexture("ui\\ui_icon_equipment")	 
		a:SetStretchTexture(true)
		self:AttachChild(a)
	end
	
	if de_item then
	
		tx = get_x(de_item.section)
		ty = get_y(de_item.section)
		tw = get_w(de_item.section)
		th = get_h(de_item.section)
		
		tx=tx*50
		ty=ty*50
		tw=tw*50
		th=th*50

		x = x-(tw/4)
		y = y-(th/4)

		a:SetOriginalRect(tx,ty,tw,th)
		a:Init(x,y,tw/2,th/2)

		--╨шёґхь яюфёҐтюы№эшъ
		if de_item.gren == 1 then
			isGrenade=true
			sect_addon=sys:r_string(di_section,"grenade_launcher_name")
			x_g=x+(sys:r_u32(di_section, "grenade_launcher_x")/2)
			y_g=y+(sys:r_u32(di_section, "grenade_launcher_y")/2)
			xa=sys:r_u32(sect_addon, "inv_grid_x")*50
			ya=sys:r_u32(sect_addon, "inv_grid_y")*50
			wa=sys:r_u32(sect_addon, "inv_grid_width")*50
			ha=sys:r_u32(sect_addon, "inv_grid_height")*50
			
			local b = self.grenade_rem_textur2	 
			
			 if not b then
				self.grenade_rem_textur2=CUIStatic()
				b = self.grenade_rem_textur2
				b:SetWindowName("grenade_rem_textur2")
				b:SetAutoDelete(true)	
				b:InitTexture("ui\\ui_icon_equipment")	 
				b:SetStretchTexture(true)
				self:AttachChild(b)
			 end
			 
			b:SetOriginalRect(xa,ya,wa,ha)
			b:Init(x_g,y_g,wa/2,ha/2)
		end

		 --╨шёґхь юяҐшіхёъшщ яЁшІхы
		if de_item.scope == 1 then
			isScope=true
			sect_addon=sys:r_string(di_section,"scope_name")
			x_sco=x+(sys:r_u32(di_section, "scope_x")/2)
			y_sco=y+(sys:r_u32(di_section, "scope_y")/2)
			xa=sys:r_u32(sect_addon, "inv_grid_x")*50
			ya=sys:r_u32(sect_addon, "inv_grid_y")*50
			wa=sys:r_u32(sect_addon, "inv_grid_width")*50
			ha=sys:r_u32(sect_addon, "inv_grid_height")*50
			
			local b = self.scope_rem_textur2	 
			
			 if not b then
				self.scope_rem_textur2 =CUIStatic()
				b = self.scope_rem_textur2 
				b:SetWindowName("scope_rem_textur2")
				b:SetAutoDelete(true)	
				b:InitTexture("ui\\ui_icon_equipment")	 
				b:SetStretchTexture(true)
				self:AttachChild(b)
			 end
			 
			b:SetOriginalRect(xa,ya,wa,ha)
			b:Init(x_sco,y_sco,wa/2,ha/2)		
		end

		--╨шёґхь уыґЇшҐхы№
		if de_item.sil == 1 then 	
			isSilencer=true
			sect_addon=sys:r_string(di_section,"silencer_name")
			x_sil=x+(sys:r_u32(di_section, "silencer_x")/2)
			y_sil=y+(sys:r_u32(di_section, "silencer_y")/2)
			xa=sys:r_u32(sect_addon, "inv_grid_x")*50
			ya=sys:r_u32(sect_addon, "inv_grid_y")*50
			wa=sys:r_u32(sect_addon, "inv_grid_width")*50
			ha=sys:r_u32(sect_addon, "inv_grid_height")*50
			
		 local b = self.silencer_rem_textur2	 
			
			 if not b then
				self.silencer_rem_textur2=CUIStatic()
				b = self.silencer_rem_textur2
				b:SetWindowName("silencer_rem_textur2")
				b:SetAutoDelete(true)	
				b:InitTexture("ui\\ui_icon_equipment")	 
				b:SetStretchTexture(true)
				self:AttachChild(b)
			 end
			 
			b:SetOriginalRect(xa,ya,wa,ha)
			b:Init(x_sil,y_sil,wa/2,ha/2)
		end

	else
		a:Init(0,0,0,0)
	end	
	
	local d1 = self.grenade_rem_textur2
	local d2 = self.scope_rem_textur2
	local d3 = self.silencer_rem_textur2
	
	if d1 and not isGrenade	then
	d1:Init(0,0,0,0)
	end

	if d2 and not isScope	then
	d2:Init(0,0,0,0)
	end
	
	if d3 and not isSilencer	then
	d3:Init(0,0,0,0)
	end

end

