end

function hugo_msg_3(first_speaker, second_speaker)
	news_manager.send_tip(db.actor, "%c[255,200,0,0]Хьюго:\n%c[default] Отличная работа, JJ! Осталось только доставить грузовик к месту эвакуации. Там мы и встретимся. Удачи!", nil, nil, 25000)
end

function hugo_msg_4(first_speaker, second_speaker)
	news_manager.send_tip(db.actor, "%c[255,200,0,0]Хьюго:\n%c[default] Жду вас на Свалке в тоннеле, не задерживайтесь.", nil, nil, 25000)
end

