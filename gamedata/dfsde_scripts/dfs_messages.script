function borman_msg_1()
	news_manager.send_tip(db.actor, "%c[255,200,0,0]Лёша Борман:\n%c[default] Если ты ещё в теме, найди на Свалке Грека. Он ждёт на старом долговском посту. У него есть кое-что для тебя.", nil, nil, 15000)
end

function borman_msg_2(first_speaker, second_speaker)
	news_manager.send_tip(db.actor, "%c[255,200,0,0]Лёша Борман:\n%c[default] Наёмник! Есть работа для тебя.", nil, nil, 15000)
end

function borman_msg_3()
	news_manager.send_tip(db.actor, "%c[255,200,0,0]Лёша Борман:\n%c[default] Наёмник! Так это ты там бузишь? Дуй ко мне, спрячу до времени.", nil, nil, 15000)
end

function borman_msg_4(first_speaker, second_speaker)
	news_manager.send_tip(db.actor, "%c[255,200,0,0]Лёша Борман:\n%c[default] Слушай сюда, бандиты. Вы вообще хоть иногда думаете?! Ложитесь на дно. Если обойдётся - сообщу.", nil, nil, 15000)
end

function unknown_msg_1(first_speaker, second_speaker)
	news_manager.send_tip(db.actor, "%c[255,200,0,0]Неизвестный:\n%c[default] Всем, кто меня слышит! Атакованы смешанной стаей мутантов! Пробиваемся в лабораторию! Просим помощи!", nil, nil, 15000)
end

function hugo_msg_1(first_speaker, second_speaker)
