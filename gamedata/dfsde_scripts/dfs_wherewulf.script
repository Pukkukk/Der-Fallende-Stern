function good_cation()
	
	local snd_obj = xr_sound.get_safe_sound_object( [[dfs\cation_1]] )
	
		snd_obj:play_no_feedback(db.actor, sound_object.s2d, 0, vector(), 1.0)
		--level.add_cam_effector("camera_effects\\earthquake.anm", 1974, false, "")
		
end

function horror_cation()
	
	local snd_obj = xr_sound.get_safe_sound_object( [[dfs\cation_2]] )
	
		snd_obj:play_no_feedback(db.actor, sound_object.s2d, 0, vector(), 1.0)
		
end

