
function ww_transformation()
	local npc = alife():story_object(19910)
	local obj = alife():story_object(19910)
	
	if npc then
	alife():set_switch_offline(npc.id, true)
	alife():set_switch_online(npc.id, false)
	alife():set_interactive(npc.id, false)
	
	alife():create("bloodsucker_strong", obj.position, obj.m_level_vertex_id, obj.m_game_vertex_id)
 
	end
end

