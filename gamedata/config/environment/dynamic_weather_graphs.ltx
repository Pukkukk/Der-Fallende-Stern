;dynamic weather graphs
;modified for SWE by ggGhosTt, zhoracementov

[weather_console_settings]
r2_ls_bloom_threshold 		= 0.0001
r2_ls_bloom_kernel_scale 	= 0.8
r2_sun_lumscale 			= 1.0
r2_sun_lumscale_amb 		= 1.0
r2_sun_lumscale_hemi 		= 0.7
r2_tonemap_adaptation 		= 1.0
r2_tonemap_amount 			= 0.7
r2_tonemap_lowlum 			= 0.0001
r2_tonemap_middlegray 		= 2.0
r_SunShafts_Blend 			= 0.01
r_SunShafts_Radius 			= 2.0

;pediod_section_name = hours_range_min, hours_range_max
[weather_periods]
1_good 				= 2, 6
2_neutral			= 2, 7
3_alpha				= 2, 3
4_bad				= 2, 5
5_foggy				= 2, 3

;starts on one hour	after prev period ending
[transition]
np_cloudy4			= 1.0

; pre blowout weathers
[pre_blowout]
pre_blowout			= 1.0

[good]
np_clear			= 0.25
np_clear2 			= 0.25
np_clear3 			= 0.25
np_clear4 			= 0.25

[neutral]
np_cloudy 			= 0.15
np_cloudy2 			= 0.10
np_cloudy2_redmoon 	= 0.05
np_cloudy3 			= 0.10
np_cloudy4 			= 0.15
np_cloudy5 			= 0.15
swtc_dark 			= 0.15
swtc_etalon 		= 0.15

[alpha]
np_alpha 			= 0.4
np_alpha2 			= 0.3
np_alpha3			= 0.3

[bad]
np_rain 			= 0.5
np_thunder 			= 0.5

[foggy]
np_foggy 			= 0.4
np_foggy_dark 		= 0.3
np_foggy_nosun 		= 0.3

[1_good]:good
[2_neutral]:neutral
[3_alpha]:alpha
[4_bad]:bad
[5_foggy]:foggy

[pripyat]:bad
[yantar]:foggy
[radar]:bad
[stancia]:bad
[sarkofag]:neutral
[stancia2]:bad