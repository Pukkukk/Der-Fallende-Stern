control_inertion_factor		= 1.15f

;отдача
cam_relax_speed 		      = 9.05		;скорость возврата в исходное положение
cam_relax_speed_ai         	= 360
cam_dispersion 			= 0.3		;увеличения угла (в градусах) с каждым выстрелом
cam_dispersion_inc		= 0.0		;увеличениe cam_dispersion с каждым выстрелом
cam_dispertion_frac		= 0.15		;ствол будет подыматься на cam_dispersion*cam_dispertion_frac +- cam_dispersion*(1-cam_dispertion_frac)
cam_max_angle			= 6.0		;максимальный угол отдачи
cam_max_angle_horz		= 8.0		;(degree) maximum shot horizontal degree 
cam_step_angle_horz		= 0.25		;(degree) size of step camera moved in horizontal position while shooting

fire_dispersion_condition_factor = 1.5		;увеличение дисперсии в процентах при максимальном износе 
misfire_probability 		   = 0.00075		;вероятность осечки при максимальном износе
misfire_condition_k		= 0.05 
condition_shot_dec 		= 0.00012 	;увеличение износа при каждом выстреле
