kill_msg_height		= 24

;-----------------------------------------------------------------------------------
;базовая дисперсия
fire_dispersion_base		= 0.15 		;угол (в градусах) базовой дисперсии оружия (оружия зажатого в тисках)
control_inertion_factor		= 1.1f

;отдача					
cam_relax_speed         	= 13.580	;скорость возврата в исходное положение
cam_dispersion          	= 0.246		;увеличения угла (в градусах) с каждым выстрелом
cam_dispersion_inc		= 0.049		;увеличениe cam_dispersion с каждым выстрелом
cam_dispertion_frac		= 0.050		;ствол будет подыматься на cam_dispersion*cam_dispertion_frac +- cam_dispersion*(1-cam_dispertion_frac)
cam_max_angle		        = 0.761	    	;максимальный угол отдачи
cam_max_angle_horz		= 0.761		;(degree) maximum shot horizontal degree 
cam_step_angle_horz		= 0.246		;(degree) size of step camera moved in horizontal position while shooting
					
fire_dispersion_condition_factor 		= 5	    	;увеличение дисперсии в процентах при максимальном износе 
misfire_probability 		= 0.005		;вероятность осечки при максимальном износе 
misfire_condition_k		= 0.05		
condition_shot_dec 		= 0.00005		;увеличение износа при каждом выстреле

