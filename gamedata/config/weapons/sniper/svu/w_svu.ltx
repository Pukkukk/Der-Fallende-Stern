;;;;;;;;;;;;;; Снайперская винтовка СВУ ;;;;;;;;;;;;;;
;-----------------------------------------------------
[wpn_svu]:identity_immunities
GroupControlSection	= spawn_group
discovery_dependency = 
$spawn                  = "weapons\svu"		; option for Level Editor
$npc			 		= on				; option for Level Editor
$prefetch 		 		= 8
scheduled               = off              	; option for ALife Simulator
cform                   = skeleton
class                   = WP_SVU
min_radius              = 50
max_radius              = 250
description				= gunsl_wpn_svu_descr
dont_interrupt_shot_anm = true ;Не прерывать анимацию выстрела чтобы гильза успела вылететь, т.к. в гансе гильзы являются частью анимации выстрела
is_gunslinger_weapon = true ;Специальный флаг чтобы двиг понимал что это ствол из Gunslinger Mod и к нему надо применить фикс создания физ. оболочки для избежания ошибок с этим связанных.	

ef_main_weapon_type		 = 3
ef_weapon_type			 = 8
hidden_bones = ironsight_off, scope1, scope2, scope3, scope4, scope5, scope6, scope7, mag20, handler2, sight_on, sight_off, sheka, firemode
;--- scope weapons -----------------------------------------------------------------
holder_range_modifier	= 2.15               ; во сколько раз увеличивается eye_range 
holder_fov_modifier		= 0.3              ; во сколько раз увеличивается eye_fov
;-----------------------------------------------------------------------------------

cost				= 12000
weapon_class			= sniper_rifle

ammo_limit		 	= 60
ammo_current			= 10
ammo_elapsed		 	= 10

f_mode				= 1

ammo_mag_size		 	= 10
ammo_class		 		= ammo_7.62x54_ap, ammo_7.62x54_7h14, ammo_7.62x54_7h1

sprint_allowed			= true;  false
;-----------------------------------------------------------------------------------
;базовая дисперсия
fire_dispersion_base		= 0.03	;угол (в градусах) базовой дисперсии оружия (оружия зажатого в тисках)
control_inertion_factor		= 1.6f

;отдача
cam_relax_speed         	= 8.5	;скорость возврата в исходное положение
cam_relax_speed_ai         	= 120.75	;скорость возврата в исходное положение
cam_dispersion          	= 1.75	;увеличения угла (в градусах) с каждым выстрелом
cam_dispersion_inc		= 0.15	;увеличениe cam_dispersion с каждым выстрелом
cam_dispertion_frac		= 0.70	;ствол будет подыматься на cam_dispersion*cam_dispertion_frac +- cam_dispersion*(1-cam_dispertion_frac)
cam_max_angle			= 12.0	;максимальный угол отдачи
cam_max_angle_horz		= 2.75	;(degree) maximum shot horizontal degree 
cam_step_angle_horz		= 0.4	;(degree) size of step camera moved in horizontal position while shooting

fire_dispersion_condition_factor = 5	;увеличение дисперсии в процентах при максимальном износе 
misfire_probability 	= 0.005	;вероятность осечки при максимальном износе 
misfire_condition_k		= 0.05
condition_shot_dec 		= 0.0002 ;увеличение износа при каждом выстреле
;-----------------------------------------------------------------------------------

hand_dependence 		= 1
single_handed			= 0

slot 			 	= 2		; // secondary
animation_slot			= 8		; type of the animation that will be used

inv_name		 	= gunsl_wpn_svu
inv_name_short		 	= gunsl_wpn_svu
inv_weight		 	= 4.4

inv_grid_width			= 5
inv_grid_height			= 2
inv_grid_x			= 0
inv_grid_y			= 2

kill_msg_x		= 0
kill_msg_y		= 59
kill_msg_width		= 80
kill_msg_height		= 26

direction               = 0, 0, 1
fire_point              = 0.0, 0.128, 0.445

;flame_particles		= weapons\generic_weapon05
smoke_particles			= weapons\generic_shoot_00
rpm_empty_click 	 	= 200

shell_point		 		= 0.0, 0.128, -0.11
shell_dir		 		= 0.0, 0.0, 0.4
shell_particles				= weapons\762x54

PDM_disp_base 			= 4.0
PDM_disp_vel_factor 		= 0.8
PDM_disp_accel_factor 		= 1.0
PDM_crouch	 		= 1.0
PDM_crouch_no_acc 		= 1.0

;;;;;;; Для "Последний Сталкер"
hit_power          = 1.0
hit_impulse	   = 90
hit_type 		   = fire_wound

fire_distance      = 500
bullet_speed	   = 830	;начальная скорость пули
rpm                = 140
; end ttc

use_aim_bullet				= true		;Поддерживается ли первая суппер пуля
time_to_aim					= 1.0	

hud                     = wpn_svu_hud
normal                  = 0, 1, 0
position                = -0.026, -0.084, 0.0
orientation             = 0, 0, 0

;--STRAP PARAMETERS-----------------------------------------------------------------
;под мишкой
strap_position         		= 0.00,-0.12,0.25 ;0.00,-0.16,0.25 ;-0.26,-0.11,0.25			; position (offset) and orientation of the weapon when it is strapped
strap_orientation      		= 182,-1,105	;175,-1,110 ;-15,-9,110				; (3rd person view in degrees)
strap_bone0					= bip01_spine2
strap_bone1					= bip01_spine1

startup_ammo            = 10
visual                  = dynamics\weapons\wpn_svu\wpn_svu.ogf

light_disabled					= true

ph_mass			 		= 3
;cost			 		= 900

;addons
scope_status			= 2
silencer_status			= 1
grenade_launcher_status	        = 0
; zoom_enabled			= true

scope_texture			= wpn\wpn_svu  ;wpn\wpn_crosshair
zoom_enabled			= true
scope_zoom_factor	        = 100		;ПСО1M1-AMK 4X

scope_name              = wpn_addon_scope
scope_names 					= wpn_addon_scope,wpn_addon_scope_cobra,wpn_addon_scope_pka,wpn_addon_scope_kashtan, wpn_addon_scope_x2.7, wpn_addon_scope_detector, wpn_addon_scope_night
scope_respawn_wpn_addon_scope = wpn_scope_pso1_svu

;;
;; Статик времени скрывается только на оптике, коллиматоры не задеваются, поэтому они остаются нетронутыми (02.11.2025)
;;

scope_respawn_wpn_addon_scope_pka = scope_pka_svu
scope_respawn_wpn_addon_scope_cobra = scope_cobra_svu

;;
;; Статик времени скрывается только на оптике, коллиматоры не задеваются, поэтому они остаются нетронутыми (02.11.2025)
;;

scope_respawn_wpn_addon_scope_kashtan = wpn_scope_kashtan_svu
scope_respawn_wpn_addon_scope_x2.7 = wpn_scope_pso1m2_svu
scope_respawn_wpn_addon_scope_detector = wpn_scope_nvsn_svu
scope_respawn_wpn_addon_scope_night = wpn_scope_nvas_svu
scope_x 				= 60
scope_y 				= -2

;------------------------------ S.T.A.L.K.E.R`s sound remake ------------------------------
;звуки
snd_draw		= weapons\svu\svu_draw
snd_holster		= weapons\vss\vss_hide
