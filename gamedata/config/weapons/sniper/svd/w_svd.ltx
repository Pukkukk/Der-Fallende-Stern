PDM_disp_base 			= 6.0
PDM_disp_vel_factor 		= 0.9
PDM_disp_accel_factor 		= 1.0
PDM_crouch	 		= 1.0
PDM_crouch_no_acc 		= 1.0

;;;;;;; Для "Последний Сталкер"
