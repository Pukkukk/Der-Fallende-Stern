light_var_color		 	= 0.05
light_var_range		 	= 0.5
light_time 		 	= 0.2

ph_mass			 		= 3
;cost			 		= 900

;addons
scope_status			= 2
silencer_status			= 0
grenade_launcher_status		= 0
; zoom_enabled				= true
scope_x 						= 60
scope_y 						= -2
scope_name 					= wpn_addon_scope			; section name for the attachable scope
scope_names 					= wpn_addon_scope,wpn_addon_scope_cobra,wpn_addon_scope_pka,wpn_addon_scope_kashtan, wpn_addon_scope_x2.7, wpn_addon_scope_detector, wpn_addon_scope_night
