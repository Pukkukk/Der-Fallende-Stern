[red_laser]
laser_light_section = laser_definition
laser_ray_bones = line

laserdot_attach_bone = line 
laserdot_attach_offset_x = 0.0
laserdot_attach_offset_y = 0.017
laserdot_attach_offset_z = -0.6

laserdot_world_attach_offset_x = 0.0
laserdot_world_attach_offset_y = 0.1
laserdot_world_attach_offset_z = 0.05

[laser_definition]
type											= 2										; type  0-Direct 1-Point 2-Spot 3-OMNIPART 4-Reflected
range           								= 250									; range                 <in meters>
range_r2        								= 250			 						; range                 <in meters>
color           								= 3.0,0.0,0.0,1.0						; four color components <r,g,b,a> 0.f<X<3.f
color_r2        								= 3.0,0.0,0.0,1.0						; four color components <r,g,b,a> 0.f<X<3.f
color_animator  								= empty									; color animator name   (empty - not using animator) //light_torch_01
volumetric						 				= false
--volumetric_for_actor							= false
volumetric_quality				 				= 1.0	
volumetric_intensity				 			= 0.15
volumetric_distance				 				= 0.1

omni_type										= 1										; type  0-Direct 1-Point 2-Spot 3-OMNIPART 4-Reflected
omni_range     									= 1.5									; range                 <in meters>
omni_range_r2   								= 0.75									; range                 <in meters>
omni_color      								= 0.4,0.35,0.35,0.1						; four color components <r,g,b,a> 0.f<X<3.f
omni_color_r2   								= 0.5,0.45,0.45,0.1						; four color components <r,g,b,a> 0.f<X<3.f

spot_texture    								= internal\internal_light_torch_r2		; spot texture name     (using only in Second Render)
--spot_texture = wpn\_wuut_pip_scopes\internal_light_torch_r2_test
spot_angle      								= 0.4									; spot angle            <in gradus>

glow_texture    								= glow\glow_torch_r2					; glow texture name     (required)
glow_radius     								= 0									; glow radius           <in meters>                              ; угол разлета света (определяет размер пятна)		; угол освещения в градусах.



[green_laser]
laser_light_section = green_laser_definition
laser_ray_bones = line

laserdot_attach_bone = line 
laserdot_attach_offset_x = 0.0
laserdot_attach_offset_y = 0.017
laserdot_attach_offset_z = -0.6

laserdot_world_attach_offset_x = 0.0
laserdot_world_attach_offset_y = 0.1
laserdot_world_attach_offset_z = 0.05

[green_laser_definition]:laser_definition

color                                           = 0.0,3.0,0.0,1.0
color_r2                                        = 0.0,3.0,0.0,1.0
                          ; угол разлета света (определяет размер пятна)		; угол освещения в градусах.



[tactical_torch]
flashlight_section = flashlight_definition

torch_cone_bones = light

torch_light_bone = wpn_body

torch_attach_offset_x = -0.008
torch_attach_offset_y = 0.048
torch_attach_offset_z = 0.0

torch_world_attach_offset_x = 0.0
torch_world_attach_offset_y = 0.05
torch_world_attach_offset_z = 0.25


torch_omni_attach_offset_x = 0.0 
torch_omni_attach_offset_y = 0.0
torch_omni_attach_offset_z = 0.0

torch_omni_world_attach_offset_x = 0.0 
torch_omni_world_attach_offset_y = 0.0
torch_omni_world_attach_offset_z = 0.0

[flashlight_definition]
;DIRECT		= 0,
;POINT		= 1,
;SPOT		= 2,
;OMNIPART	= 3,
;REFLECTED	= 4,
omni_type = 2 ;KRodin: вообще omni это обычно поинт, но поинт светит во все стороны от себя, поэтому тут спот используется.

range           = 50	                            ; дальность в метрах
range_r2        = 50	                            ; дальность в метрах (для динамического освещения)
color           = 1.0,1.0,1.0,0.6					; цвет, из 4 компонентов <r,g,b,a> значением от 0 до 3.
color_r2        = 1.0,1.1,1.2,1.2					; цвет, из 4 компонентов <r,g,b,a> значением от 0 до 3. (для динамического освещения)
omni_range      = 0.25								; дистанция освещения от фонариков неписей в метрах.
omni_range_r2   = 0.25								; дистанция освещения от фонариков неписей в метрах. (для динамического освещения)
omni_color      = 1.0,1.0,1.0,0.3					; цвет фонариков неписей, из 4 компонентов <r,g,b,a> значением от 0 до 3.
omni_color_r2   = 1.0,1.1,1.2,0.2					; цвет фонариков неписей, из 4 компонентов <r,g,b,a> значением от 0 до 3. (для динамического освещения)
color_animator  = empty								; цвет аниматора (empty - аниматор не используется). //light_torch_01
spot_texture    = internal\internal_light_torch_tactical_r2 ; текстура яркой точки (только для динамического освещения).
spot_angle      = 60	                            ; угол разлета света (определяет размер пятна)		; угол освещения в градусах.
glow_texture    = glow\glow_torch_r2			    ; текстура свечения фонарика, когда он направлен в глаза (обязательный параметр).
glow_radius     = 0.3								; радиус свечения в метрах.




[hand_torch_light]
