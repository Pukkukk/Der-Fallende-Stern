[logic]
active = ph_door@close

[ph_door@close]
locked = false
closed = true
snd_open_start = trader_door_open_start
snd_close_start = trader_door_close_start
snd_close_stop = trader_door_close_stop
on_use = ph_door@open
on_info = {+player_complete_lost_helicopter +player_complete_find_sor_sniper} ph_door@strakhovka

[ph_door@open]
locked = false
closed = false
snd_open_start = trader_door_open_start
snd_close_start = trader_door_close_start
snd_close_stop = trader_door_close_stop
on_use = ph_door@close
on_info = {+player_complete_lost_helicopter +player_complete_find_sor_sniper} ph_door@strakhovka

[ph_door@strakhovka]
locked = true
closed = true
on_info = {+find_lost_commandos_start +lost_priest_start} ph_door@close1

[ph_door@close1]
locked = false
closed = true
snd_open_start = trader_door_open_start
snd_close_start = trader_door_close_start
snd_close_stop = trader_door_close_stop
on_use = ph_door@open1

[ph_door@open1]
locked = false
closed = false
snd_open_start = trader_door_open_start
snd_close_start = trader_door_close_start
snd_close_stop = trader_door_close_stop
on_use = ph_door@close1